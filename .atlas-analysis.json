  "keyFeatures": [
    "Product analytics with autocapture and custom events",
    "Session replay with console logs and network monitoring",
    "Feature flags with multivariate testing and rollout controls",
    "A/B testing and experimentation with statistical analysis",
    "User surveys with no-code templates",
    "Error tracking with stack traces and source maps",
    "Data warehouse with SQL querying and external integrations",
    "Data pipelines (CDP) with real-time transformations",
    "LLM analytics for tracking traces and generations",
    "Web analytics with GA-like dashboard"
